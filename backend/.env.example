# Copy to backend/.env and fill in real values. Never commit the real .env.

# Required for live mode (Gemini 2.5-Flash analysis + Embeddings RAG + Vision).
# Without this the server runs in heuristic offline mode.
GEMINI_API_KEY=

# Optional. Set to a Google Chat webhook URL to enable auto-dispatch alerts
# when a request scores >= 80.
GOOGLE_CHAT_WEBHOOK_URL=

# Set to "false" (or leave the line off) to gate Google Search grounding
# and conserve Free-Tier quota. Set to "true" once billing is active.
ENABLE_GROUNDING=false

# Optional. Comma-separated list of allowed origins for CORS + Socket.io.
# Use the Vercel URL of the deployed frontend in production, e.g.:
#   CORS_ORIGIN=https://ai-rescuenet.vercel.app
# Leave unset (or '*') to allow any origin (fine for local dev).
CORS_ORIGIN=

# PORT is provided by Render automatically; only set locally if needed.
# PORT=5000
